PORT=3000
NODE_ENV=production
ADMIN_TOKEN=замените-на-длинный-секретный-токен
# SMS.ru — подтверждение телефона при заказе
SMSRU_API_ID=ваш-api-id-sms-ru
# Имя отправителя после согласования в SMS.ru (например MOTIVATOR)
SMSRU_FROM=MOTIVATOR
# На Render с диском: DATA_DIR=/var/data
# Локально можно не указывать
# DATA_DIR=
